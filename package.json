{
  "name": "kodex-studio-web",
  "version": "1.0.0",
  "scripts": {
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "format": "prettier --write .",
    "format:frontend": "prettier --write frontend/",
    "format:check": "prettier --check .",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "cd frontend && npm run test",
    "test:backend": "cd backend && npm run test",
    "clean": "rimraf frontend/dist backend/dist frontend/node_modules backend/node_modules node_modules",
    "clean:build": "rimraf frontend/dist backend/dist",
    "db:push": "cd backend && npm run db:push",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:generate": "cd backend && npm run db:generate",
    "db:studio": "cd backend && npm run db:studio",
    "db:sync": "cd backend && npm run db:sync"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.0.0-insiders.f7d2598",
    "rimraf": "^6.1.3"
  }
}
