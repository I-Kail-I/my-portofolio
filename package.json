{
  "name": "kodex-studio-web",
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "lint": "concurrently -n frontend,backend -c cyan,red \"npm run lint:frontend\" \"npm run lint:backend\"",
    "lint:frontend": "npm run lint --workspace=frontend",
    "lint:backend": "npm run lint --workspace=backend",
    "format": "prettier --write .",
    "format:frontend": "prettier --write frontend/",
    "format:check": "prettier --check .",
    "test": "concurrently -n frontend,backend -c cyan,red \"npm run test:frontend\" \"npm run test:backend\"",
    "test:frontend": "npm run test --workspace=frontend",
    "test:backend": "npm run test --workspace=backend",
    "clean": "rimraf frontend/dist backend/dist frontend/node_modules backend/node_modules node_modules",
    "clean:build": "rimraf frontend/dist backend/dist",
    "db:push": "npm run db:push --workspace=backend",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:generate": "npm run db:generate --workspace=backend",
    "db:studio": "npm run db:studio --workspace=backend",
    "db:sync": "npm run db:sync --workspace=backend"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.0.0-insiders.f7d2598"
  }
}
